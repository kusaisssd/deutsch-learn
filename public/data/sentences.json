  { "id": 201, "level": "B1", "english": "When I have time, I read books",                     "germanWords": ["Wenn", "ich", "Zeit", "habe,", "lese", "ich", "Bücher"], "hint": "wenn-clause inverts subject and verb" },
  { "id": 202, "level": "B1", "english": "I believe that he is right",                          "germanWords": ["Ich", "glaube,", "dass", "er", "recht", "hat"], "hint": "dass-clause: verb at end" },
  { "id": 203, "level": "B1", "english": "She says that she is tired",                          "germanWords": ["Sie", "sagt,", "dass", "sie", "müde", "ist"] },
  { "id": 204, "level": "B1", "english": "I am learning German because I want to move to Berlin","germanWords": ["Ich", "lerne", "Deutsch,", "weil", "ich", "nach", "Berlin", "ziehen", "will"] },
  { "id": 205, "level": "B1", "english": "Although it is raining, we go for a walk",            "germanWords": ["Obwohl", "es", "regnet,", "gehen", "wir", "spazieren"] },
  { "id": 206, "level": "B1", "english": "I think that is a good idea",                          "germanWords": ["Ich", "denke,", "dass", "das", "eine", "gute", "Idee", "ist"] },
  { "id": 207, "level": "B1", "english": "If I had money, I would travel",                      "germanWords": ["Wenn", "ich", "Geld", "hätte,", "würde", "ich", "reisen"], "hint": "Konjunktiv II (hypothetical)" },
  { "id": 208, "level": "B1", "english": "I would like to drink a coffee",                       "germanWords": ["Ich", "würde", "gerne", "einen", "Kaffee", "trinken"] },
  { "id": 209, "level": "B1", "english": "We would have liked to invite you",                    "germanWords": ["Wir", "hätten", "dich", "gerne", "eingeladen"] },
  { "id": 210, "level": "B1", "english": "The book that I am reading is interesting",            "germanWords": ["Das", "Buch,", "das", "ich", "lese,", "ist", "interessant"], "hint": "Relative clause" },
  { "id": 211, "level": "B1", "english": "The man who stands there is my uncle",                 "germanWords": ["Der", "Mann,", "der", "dort", "steht,", "ist", "mein", "Onkel"] },
  { "id": 212, "level": "B1", "english": "I look forward to seeing you",                         "germanWords": ["Ich", "freue", "mich", "darauf,", "dich", "zu", "sehen"], "hint": "da-compound + zu-infinitive" },
  { "id": 213, "level": "B1", "english": "It is important to eat healthily",                    "germanWords": ["Es", "ist", "wichtig,", "gesund", "zu", "essen"] },
  { "id": 214, "level": "B1", "english": "She tries to learn every day",                         "germanWords": ["Sie", "versucht,", "jeden", "Tag", "zu", "lernen"] },
  { "id": 215, "level": "B1", "english": "Berlin is bigger than Munich",                         "germanWords": ["Berlin", "ist", "größer", "als", "München"], "hint": "Comparative" },
  { "id": 216, "level": "B1", "english": "That is the best pizza in the city",                   "germanWords": ["Das", "ist", "die", "beste", "Pizza", "der", "Stadt"], "hint": "Superlative" },
  { "id": 217, "level": "B1", "english": "The more I learn, the better I get",                   "germanWords": ["Je", "mehr", "ich", "lerne,", "desto", "besser", "werde", "ich"] },
  { "id": 218, "level": "B1", "english": "I forgot to bring the key",                            "germanWords": ["Ich", "habe", "vergessen,", "den", "Schlüssel", "mitzunehmen"] },
  { "id": 219, "level": "B1", "english": "If you ask, I will gladly help you",                   "germanWords": ["Wenn", "du", "fragst,", "helfe", "ich", "dir", "gerne"] },
  { "id": 220, "level": "B1", "english": "He is not coming because he is sick",                  "germanWords": ["Er", "kommt", "nicht,", "weil", "er", "krank", "ist"] },
  { "id": 221, "level": "B1", "english": "I heard that you are getting married",                 "germanWords": ["Ich", "habe", "gehört,", "dass", "du", "heiraten", "wirst"] },
  { "id": 222, "level": "B1", "english": "Nobody knows where he is",                             "germanWords": ["Niemand", "weiß,", "wo", "er", "ist"] },
  { "id": 223, "level": "B1", "english": "She asks whether we are coming",                       "germanWords": ["Sie", "fragt,", "ob", "wir", "kommen"] },
  { "id": 224, "level": "B1", "english": "It is possible that it will rain",                     "germanWords": ["Es", "ist", "möglich,", "dass", "es", "regnet"] },
  { "id": 225, "level": "B1", "english": "I am sure that everything will be fine",               "germanWords": ["Ich", "bin", "sicher,", "dass", "alles", "gut", "wird"] },
  { "id": 226, "level": "B1", "english": "We have to hurry, otherwise we will be late",          "germanWords": ["Wir", "müssen", "uns", "beeilen,", "sonst", "kommen", "wir", "zu", "spät"] },
  { "id": 227, "level": "B1", "english": "Before I leave, I want to say goodbye",                "germanWords": ["Bevor", "ich", "gehe,", "möchte", "ich", "mich", "verabschieden"] },
  { "id": 228, "level": "B1", "english": "After he had eaten, he went for a walk",               "germanWords": ["Nachdem", "er", "gegessen", "hatte,", "ging", "er", "spazieren"], "hint": "Plusquamperfekt + nachdem" },
  { "id": 229, "level": "B1", "english": "While I was cooking, I sang a song",                   "germanWords": ["Während", "ich", "kochte,", "sang", "ich", "ein", "Lied"] },
  { "id": 230, "level": "B1", "english": "I remember my first day",                              "germanWords": ["Ich", "erinnere", "mich", "an", "meinen", "ersten", "Tag"] },
  { "id": 231, "level": "B1", "english": "We thank you for your help",                           "germanWords": ["Wir", "bedanken", "uns", "für", "deine", "Hilfe"] },
