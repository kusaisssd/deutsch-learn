  { "id": 233, "level": "B1", "english": "She has decided to stay",                              "germanWords": ["Sie", "hat", "sich", "entschieden", "zu", "bleiben"] },
  { "id": 234, "level": "B1", "english": "It is worth getting up early",                         "germanWords": ["Es", "lohnt", "sich,", "früh", "aufzustehen"] },
  { "id": 235, "level": "B1", "english": "I am afraid of getting lost",                          "germanWords": ["Ich", "habe", "Angst,", "mich", "zu", "verlaufen"] },
  { "id": 236, "level": "B1", "english": "We should drink more water",                           "germanWords": ["Wir", "sollten", "mehr", "Wasser", "trinken"] },
  { "id": 237, "level": "B1", "english": "I could not do this without you",                      "germanWords": ["Ich", "könnte", "das", "nicht", "ohne", "dich", "machen"] },
  { "id": 238, "level": "B1", "english": "Would you please help me?",                            "germanWords": ["Würden", "Sie", "mir", "bitte", "helfen?"] },
  { "id": 239, "level": "B1", "english": "I would not have thought that",                        "germanWords": ["Ich", "hätte", "das", "nicht", "gedacht"] },
  { "id": 240, "level": "B1", "english": "In your place I would act differently",                "germanWords": ["An", "deiner", "Stelle", "würde", "ich", "anders", "handeln"] },
  { "id": 241, "level": "B1", "english": "There are many reasons to learn German",                "germanWords": ["Es", "gibt", "viele", "Gründe,", "Deutsch", "zu", "lernen"] },
  { "id": 242, "level": "B1", "english": "I find it important to be polite",                     "germanWords": ["Ich", "finde", "es", "wichtig,", "höflich", "zu", "sein"] },
  { "id": 243, "level": "B1", "english": "Instead of working, he slept",                         "germanWords": ["Statt", "zu", "arbeiten,", "hat", "er", "geschlafen"] },
  { "id": 244, "level": "B1", "english": "Without you I would be lost",                          "germanWords": ["Ohne", "dich", "wäre", "ich", "verloren"] },
  { "id": 245, "level": "B1", "english": "Because of the rain we stay home",                     "germanWords": ["Wegen", "des", "Regens", "bleiben", "wir", "zuhause"], "hint": "wegen + Genitiv" },
  { "id": 246, "level": "B1", "english": "Despite the cold we go outside",                       "germanWords": ["Trotz", "der", "Kälte", "gehen", "wir", "raus"] },
  { "id": 247, "level": "B1", "english": "Instead of complaining, we should act",                "germanWords": ["Anstatt", "zu", "klagen,", "sollten", "wir", "handeln"] },
  { "id": 248, "level": "B1", "english": "I am of the opinion that this is wrong",               "germanWords": ["Ich", "bin", "der", "Meinung,", "dass", "das", "falsch", "ist"] },
  { "id": 249, "level": "B1", "english": "In my experience this is not easy",                    "germanWords": ["Meiner", "Erfahrung", "nach", "ist", "das", "nicht", "einfach"] },
  { "id": 250, "level": "B1", "english": "It depends on what you want",                          "germanWords": ["Es", "kommt", "darauf", "an,", "was", "du", "willst"] },

  { "id": 301, "level": "B2", "english": "Despite the bad weather, we decided to go for a walk",     "germanWords": ["Trotz", "des", "schlechten", "Wetters", "haben", "wir", "uns", "entschieden,", "spazieren", "zu", "gehen"] },
  { "id": 302, "level": "B2", "english": "She speaks not only German but also French",                "germanWords": ["Sie", "spricht", "nicht", "nur", "Deutsch,", "sondern", "auch", "Französisch"], "hint": "nicht nur ... sondern auch" },
  { "id": 303, "level": "B2", "english": "If I had known, I would have come earlier",                 "germanWords": ["Wenn", "ich", "gewusst", "hätte,", "wäre", "ich", "früher", "gekommen"], "hint": "Konjunktiv II Vergangenheit" },
  { "id": 304, "level": "B2", "english": "The book was written by a famous author",                   "germanWords": ["Das", "Buch", "wurde", "von", "einem", "berühmten", "Autor", "geschrieben"], "hint": "Passive voice" },
  { "id": 305, "level": "B2", "english": "The contract must be signed by tomorrow",                   "germanWords": ["Der", "Vertrag", "muss", "bis", "morgen", "unterschrieben", "werden"], "hint": "Modal + passive" },
  { "id": 306, "level": "B2", "english": "It is recommended to exercise regularly",                   "germanWords": ["Es", "wird", "empfohlen,", "regelmäßig", "Sport", "zu", "treiben"] },
  { "id": 307, "level": "B2", "english": "Had he gotten up on time, he would have caught the train",  "germanWords": ["Wäre", "er", "rechtzeitig", "aufgestanden,", "hätte", "er", "den", "Zug", "erwischt"] },
  { "id": 308, "level": "B2", "english": "The longer I think about it, the more uncertain I become",  "germanWords": ["Je", "länger", "ich", "darüber", "nachdenke,", "desto", "unsicherer", "werde", "ich"] },
  { "id": 309, "level": "B2", "english": "Although he is very busy, he gladly helps others",          "germanWords": ["Obwohl", "er", "sehr", "beschäftigt", "ist,", "hilft", "er", "anderen", "gerne"] },
  { "id": 310, "level": "B2", "english": "It would have been better if you had asked earlier",         "germanWords": ["Es", "wäre", "besser", "gewesen,", "wenn", "du", "früher", "gefragt", "hättest"] },
  { "id": 311, "level": "B2", "english": "I doubt that was the right decision",                       "germanWords": ["Ich", "bezweifle,", "dass", "das", "die", "richtige", "Entscheidung", "war"] },
  { "id": 312, "level": "B2", "english": "Given the circumstances, we have no other choice",          "germanWords": ["Angesichts", "der", "Umstände", "haben", "wir", "keine", "andere", "Wahl"] },
  { "id": 313, "level": "B2", "english": "In contrast to his brother, he is very calm",               "germanWords": ["Im", "Gegensatz", "zu", "seinem", "Bruder", "ist", "er", "sehr", "ruhig"] },
  { "id": 314, "level": "B2", "english": "As for me, I am of a completely different opinion",         "germanWords": ["Was", "mich", "betrifft,", "bin", "ich", "völlig", "anderer", "Meinung"] },
  { "id": 315, "level": "B2", "english": "As soon as the sun rises, the day begins",                  "germanWords": ["Sobald", "die", "Sonne", "aufgeht,", "beginnt", "der", "Tag"] },
  { "id": 316, "level": "B2", "english": "This concerns an important problem",                        "germanWords": ["Es", "handelt", "sich", "um", "ein", "wichtiges", "Problem"] },
  { "id": 317, "level": "B2", "english": "The politicians have agreed on a compromise",               "germanWords": ["Die", "Politiker", "haben", "sich", "auf", "einen", "Kompromiss", "geeinigt"] },
  { "id": 318, "level": "B2", "english": "This theory is supported by many scientists",               "germanWords": ["Diese", "Theorie", "wird", "von", "vielen", "Wissenschaftlern", "unterstützt"] },
  { "id": 319, "level": "B2", "english": "It cannot be denied that technology has changed us",         "germanWords": ["Es", "ist", "nicht", "zu", "leugnen,", "dass", "die", "Technologie", "uns", "verändert", "hat"] },
  { "id": 320, "level": "B2", "english": "One should never do something one might later regret",       "germanWords": ["Man", "sollte", "nie", "etwas", "tun,", "was", "man", "später", "bereuen", "könnte"] },
  { "id": 321, "level": "B2", "english": "He claims to have done everything alone",                   "germanWords": ["Er", "behauptet,", "alles", "allein", "geschafft", "zu", "haben"] },
  { "id": 322, "level": "B2", "english": "The meeting was postponed due to an emergency",             "germanWords": ["Die", "Sitzung", "wurde", "aufgrund", "eines", "Notfalls", "verschoben"] },
  { "id": 323, "level": "B2", "english": "As long as you do your best, you cannot lose",              "germanWords": ["Solange", "du", "dein", "Bestes", "gibst,", "kannst", "du", "nicht", "verlieren"] },
  { "id": 324, "level": "B2", "english": "If you have questions, do not hesitate to ask",             "germanWords": ["Falls", "Sie", "Fragen", "haben,", "zögern", "Sie", "nicht", "zu", "fragen"] },
  { "id": 325, "level": "B2", "english": "It cannot be disputed that the climate is changing",        "germanWords": ["Es", "lässt", "sich", "nicht", "bestreiten,", "dass", "das", "Klima", "sich", "ändert"] },
  { "id": 326, "level": "B2", "english": "According to the newspaper, she supposedly won the prize",  "germanWords": ["Sie", "soll", "laut", "Zeitung", "den", "Preis", "gewonnen", "haben"] },
  { "id": 327, "level": "B2", "english": "Nevertheless, many questions remain unanswered",            "germanWords": ["Trotzdem", "bleiben", "viele", "Fragen", "unbeantwortet"] },
  { "id": 328, "level": "B2", "english": "The city has developed strongly in recent years",           "germanWords": ["Die", "Stadt", "hat", "sich", "in", "den", "letzten", "Jahren", "stark", "entwickelt"] },
  { "id": 329, "level": "B2", "english": "It seems to me that you are hiding something",              "germanWords": ["Mir", "scheint,", "dass", "du", "etwas", "verschweigst"] },
  { "id": 330, "level": "B2", "english": "It is not rare that plans change",                          "germanWords": ["Es", "kommt", "nicht", "selten", "vor,", "dass", "Pläne", "sich", "ändern"] },
  { "id": 331, "level": "B2", "english": "The importance of this decision must not be underestimated","germanWords": ["Die", "Bedeutung", "dieser", "Entscheidung", "darf", "nicht", "unterschätzt", "werden"] },
  { "id": 332, "level": "B2", "english": "Had we known, we would not have come",                       "germanWords": ["Hätten", "wir", "das", "gewusst,", "wären", "wir", "nicht", "gekommen"] },
  { "id": 333, "level": "B2", "english": "I assume that he will answer soon",                          "germanWords": ["Ich", "nehme", "an,", "dass", "er", "bald", "antworten", "wird"] },
  { "id": 334, "level": "B2", "english": "It remains to be seen how the situation develops",          "germanWords": ["Es", "bleibt", "abzuwarten,", "wie", "sich", "die", "Lage", "entwickelt"] },
  { "id": 335, "level": "B2", "english": "The negotiations have been dragging on for weeks",          "germanWords": ["Die", "Verhandlungen", "ziehen", "sich", "seit", "Wochen", "hin"] },
  { "id": 336, "level": "B2", "english": "It is extremely important that we work together",           "germanWords": ["Es", "ist", "äußerst", "wichtig,", "dass", "wir", "zusammenarbeiten"] },
  { "id": 337, "level": "B2", "english": "Young people in particular are affected by this",           "germanWords": ["Insbesondere", "junge", "Menschen", "sind", "davon", "betroffen"] },
  { "id": 338, "level": "B2", "english": "The case was closed due to lack of evidence",               "germanWords": ["Aufgrund", "mangelnder", "Beweise", "wurde", "der", "Fall", "geschlossen"] },
  { "id": 339, "level": "B2", "english": "Regarding the budget, we still need to discuss",            "germanWords": ["Hinsichtlich", "des", "Budgets", "müssen", "wir", "noch", "diskutieren"] },
  { "id": 340, "level": "B2", "english": "In other words, we agree",                                   "germanWords": ["Mit", "anderen", "Worten,", "wir", "sind", "uns", "einig"] },
  { "id": 341, "level": "B2", "english": "It should be noted that every rule has exceptions",         "germanWords": ["Es", "gilt", "zu", "beachten,", "dass", "jede", "Regel", "Ausnahmen", "hat"] },
  { "id": 342, "level": "B2", "english": "Aside from that, everything is in order",                   "germanWords": ["Davon", "abgesehen", "ist", "alles", "in", "Ordnung"] },
  { "id": 343, "level": "B2", "english": "By and large, the event was successful",                    "germanWords": ["Im", "Großen", "und", "Ganzen", "war", "die", "Veranstaltung", "erfolgreich"] },
  { "id": 344, "level": "B2", "english": "This experience has changed my life",                       "germanWords": ["Diese", "Erfahrung", "hat", "mein", "Leben", "verändert"] },
  { "id": 345, "level": "B2", "english": "It is important to me to help you",                         "germanWords": ["Es", "liegt", "mir", "am", "Herzen,", "dir", "zu", "helfen"] },
  { "id": 346, "level": "B2", "english": "No matter what happens, I will support you",                "germanWords": ["Egal", "was", "passiert,", "ich", "werde", "dich", "unterstützen"] },
  { "id": 347, "level": "B2", "english": "Meanwhile, I have changed my mind",                         "germanWords": ["Inzwischen", "habe", "ich", "meine", "Meinung", "geändert"] },
  { "id": 348, "level": "B2", "english": "It is high time to change something",                       "germanWords": ["Es", "ist", "höchste", "Zeit,", "etwas", "zu", "ändern"] },
  { "id": 349, "level": "B2", "english": "As far as I know, the store is closed today",               "germanWords": ["Soweit", "ich", "weiß,", "ist", "das", "Geschäft", "heute", "geschlossen"] },
  { "id": 350, "level": "B2", "english": "The effects will be felt for a long time",                  "germanWords": ["Die", "Auswirkungen", "werden", "noch", "lange", "spürbar", "sein"] }
]
